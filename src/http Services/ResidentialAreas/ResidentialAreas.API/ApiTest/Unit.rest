###

# Filter units - all
GET {{baseUrl}}/units/filter

###

# Filter units - by building code
GET {{baseUrl}}/units/filter?buildingCode=2000000000

###

# Filter units - by unit type and occupancy status
GET {{baseUrl}}/units/filter?unitType=Apartment&occupancyStatus=Vacant

###

# Filter units - by ownership type
GET {{baseUrl}}/units/filter?ownershipType=Owned