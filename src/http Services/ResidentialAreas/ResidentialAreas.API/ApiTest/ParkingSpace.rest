###

# Filter Parking Spaces - by area code
GET {{baseUrl}}/parking-spaces/filter?areaCode=1000000000

###

# Filter Parking Spaces - by block and status
GET {{baseUrl}}/parking-spaces/filter?blockNo=A&status=Active

###

# Filter Parking Spaces - by name
GET {{baseUrl}}/parking-spaces/filter?name=Parking%20Space%201

